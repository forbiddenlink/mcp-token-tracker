{
  "name": "mcp-token-tracker",
  "version": "1.0.0",
  "description": "Track MCP server token usage and costs for AI coding tools",
  "type": "module",
  "bin": {
    "mcp-token-tracker": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts scan",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "mcp",
    "tokens",
    "cursor",
    "windsurf",
    "claude",
    "ai",
    "cost"
  ],
  "author": "Elizabeth Stein",
  "license": "MIT",
  "private": false,
  "packageManager": "pnpm@10.29.1",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "tiktoken": "^1.0.22",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/update-notifier": "^6.0.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "express-rate-limit": ">=8.2.2",
      "hono": ">=4.12.12",
      "path-to-regexp": ">=8.4.0",
      "@hono/node-server": ">=1.19.13"
    }
  }
}
